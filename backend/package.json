{
  "name": "crowdpulse-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "tsc && node dist/server.js",
    "dev": "nodemon -e ts,js --exec ts-node server.ts",
    "test": "jest --testTimeout=15000",
    "test:watch": "jest --watch --detectOpenHandles"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "routes/**/*.js",
      "data/**/*.js",
      "app.js"
    ]
  },
  "keywords": [],
  "author": "CrowdPulse Team",
  "license": "ISC",
  "description": "CrowdPulse Backend — Real-time venue intelligence API",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.15.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "firebase-admin": "^13.8.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
